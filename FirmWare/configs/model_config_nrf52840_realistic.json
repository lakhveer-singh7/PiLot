{
  "model": {
    "name": "nRF52840_UniformCNN",
    "version": "2.0"
  },
  
  "global": {
    "dataset": "Cricket_X",
    "epochs": 20,
    "num_classes": 12,
    "input_length": 300,
    "memory_limit_bytes": 220000
  },
  
  "layers": [
    {
      "id": 0,
      "type": "conv1d",
      "in_channels": 1,
      "out_channels": 32,
      "kernel_size": 5,
      "stride": 1,
      "padding": 2,
      "num_devices": 2
    },
    {
      "id": 1,
      "type": "conv1d",
      "in_channels": 32,
      "out_channels": 48,
      "kernel_size": 5,
      "stride": 1,
      "padding": 2,
      "num_devices": 3
    },
    {
      "id": 2,
      "type": "conv1d",
      "in_channels": 48,
      "out_channels": 64,
      "kernel_size": 5,
      "stride": 1,
      "padding": 2,
      "num_devices": 4
    },
    {
      "id": 3,
      "type": "fc",
      "in_features": 128,
      "out_features": 12
    }
  ]
}